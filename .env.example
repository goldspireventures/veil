# Goldspire Secure Text — extension configuration
# Official local repo: C:\Users\eamon\Personal Projects\secure-text
# Copy to .env and edit. Then apply:
#   npm run env:apply
#   — or on Windows PowerShell if npm is blocked:
#   npm.cmd run env:apply
#   node scripts/apply-env.mjs

# Cloud org API (self-serve teams). Leave empty to disable cloud join.
ORG_API_BASE=http://localhost:3015

# Organization sign-in / join portal
# Production example (Cloudflare Pages):
# ORG_PORTAL_URL=https://join-secure-text.goldspireventures.com/join.html
ORG_PORTAL_URL=http://localhost:3015/secure-text/join

# CORS allow-list for the local org API (comma-separated origins).
# Only needed for the join portal web page; the extension can talk to the API directly.
# Example: CORS_ALLOW_ORIGINS=http://localhost:3015,https://your-domain.example
# Default: unset (CORS disabled)
# Production example:
# CORS_ALLOW_ORIGINS=https://join-secure-text.goldspireventures.com

# Hosted unlock page (GitHub Pages). Production default below.
BUILT_IN_PUBLIC_UNLOCK_URL=https://goldspire-global.github.io/secure-text/unlock.html

# Background sync interval (minutes)
ORG_SYNC_INTERVAL_MINUTES=360

# ---- Cloud org API database (Supabase Postgres) ----
# Transaction pooler (port 6543) — used by api/ at runtime
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Session pooler (port 5432) — used for migrations (db:migrate)
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Local API port (default 3015)
# API_PORT=3015

# ---- Stripe (Team billing — use test keys locally) ----
# STRIPE_SECRET_KEY=sk_test_...
# Run `npm run stripe:listen` and paste the whsec_... secret it prints:
# STRIPE_WEBHOOK_SECRET=whsec_...
# Production webhook URL (live mode destination in Stripe Dashboard):
#   https://secure-text-api.goldspireventures.com/v1/webhooks/stripe
# Optional when Checkout is enabled:
# STRIPE_PRICE_ID_TEAM_MONTHLY=price_...
# STRIPE_BILLING_PORTAL_URL=https://join-secure-text.goldspireventures.com/pricing.html
