# Veil by Goldspire — extension configuration
# Official local repo: C:\Users\eamon\Personal Projects\veil
# Copy to .env and edit. Then apply:
#   npm run env:apply
#   — or on Windows PowerShell if npm is blocked:
#   npm.cmd run env:apply
#   node scripts/apply-env.mjs

# Cloud org API (self-serve teams). Leave empty to disable cloud join.
ORG_API_BASE=http://localhost:3015

# Organization sign-in / join portal
# Production example (Cloudflare Pages):
# ORG_PORTAL_URL=https://veil.goldspireventures.com/join.html
ORG_PORTAL_URL=http://localhost:3015/join.html

# CORS allow-list for the local org API (comma-separated origins).
# Only needed for the join portal web page; the extension can talk to the API directly.
# Example: CORS_ALLOW_ORIGINS=http://localhost:3015,https://your-domain.example
# Default: unset (CORS disabled)
# Production example:
# CORS_ALLOW_ORIGINS=https://veil.goldspireventures.com

# Hosted unlock page (GitHub Pages). Production default below.
BUILT_IN_PUBLIC_UNLOCK_URL=https://veil.goldspireventures.com/unlock.html

# Background sync interval (minutes)
ORG_SYNC_INTERVAL_MINUTES=360

# ---- Cloud org API database (Supabase Postgres) ----
# Transaction pooler (port 6543) — used by api/ at runtime
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Session pooler (port 5432) — used for migrations (db:migrate)
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Local API port (default 3015)
# API_PORT=3015

# ---- Stripe (Team billing — use test keys locally) ----
# STRIPE_SECRET_KEY=sk_test_...
# Run `npm run stripe:setup` to create Veil Team product + payment link in Stripe.
# Run `npm run stripe:listen` and paste the whsec_... secret it prints:
# STRIPE_WEBHOOK_SECRET=whsec_...
# Production webhook URL (live mode destination in Stripe Dashboard):
#   https://veil-api.goldspireventures.com/v1/webhooks/stripe
# STRIPE_PRICE_ID_TEAM_ANNUAL=price_...
# STRIPE_PRICE_ID_TEAM_MONTHLY=price_...
# STRIPE_PAYMENT_LINK_TEAM=https://buy.stripe.com/...
# STRIPE_BILLING_PORTAL_URL=https://billing.stripe.com/p/login/...
# VEIL_EARLY_ACCESS=false
# Optional ISO end date — portal + API switch to paid after this day.
# Example: VEIL_EARLY_ACCESS_END=2026-12-31
# VEIL_BILLING_GRACE_DAYS=14
# Or flip immediately: VEIL_EARLY_ACCESS=false then npm run env:apply and redeploy API + Pages.

# ---- Browser store (install page direct links) ----
# STORE_URL_EDGE=https://microsoftedge.microsoft.com/addons/detail/veil/kfnpkdgfdpalmfibbkblkoncafpmcpkd
# STORE_URL_CHROME=https://chromewebstore.google.com/detail/veil/<extension-id>
# RESEND_API_KEY=re_...          # Branded invites + weekly admin digests
# VEIL_EMAIL_FROM=Veil <noreply@yourdomain.com>

# ---- Contact emails (portal + extension feedback) ----
# SUPPORT_EMAIL=support@goldspireventures.com
# SECURITY_EMAIL=security@goldspireventures.com
# PRIVACY_EMAIL=privacy@goldspireventures.com
# SALES_EMAIL=sales@goldspireventures.com
# LEGAL_EMAIL=legal@goldspireventures.com

# ---- In-house platform ops (no third-party APM) ----
# Set a long random token; use on https://veil-api…/ops.html
# PLATFORM_OPS_TOKEN=
# Shared key baked into extension via npm run env:apply
# OPS_CLIENT_INGEST_KEY=
# HMAC secret for signed learning bundles (same value in extension via env:apply)
# LEARNING_BUNDLE_SECRET=
# Run full learning train once per day on API (default: on; set false to disable)
# LEARNING_AUTO_TRAIN=true
# Threshold-based auto-train after decision ingest (defaults shown)
# LEARNING_TRAIN_COOLDOWN_HOURS=4
# LEARNING_TRAIN_MIN_DECISIONS=20
# LEARNING_TRAIN_MIN_SAMPLES=10
# Optional webhook for critical alerts (Microsoft Teams recommended)
# OPS_ALERT_WEBHOOK_TYPE=teams
# OPS_ALERT_WEBHOOK_URL=https://…webhook.office.com/…
